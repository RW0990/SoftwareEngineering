<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Merchandise</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="stylesheet" href="/style.css" />
  </head>

  <body>
<body>

  <%- include('partials/nav') %>

  <main class="product-grid">

    <main class="product-grid">
